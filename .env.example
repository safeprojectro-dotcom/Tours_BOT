# Copy this file to `.env` for local development.
# Keep real secrets and environment-specific values out of version control.

APP_NAME=Tours_BOT
APP_ENV=local
APP_DEBUG=true
APP_HOST=127.0.0.1
APP_PORT=8000
APP_LOG_LEVEL=INFO
# Local PostgreSQL-first development target.
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/tours_bot
DATABASE_CONNECT_TIMEOUT=5
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBHOOK_SECRET=
# Public HTTPS origin of this API (no path), for: python -m app.cli.telegram_webhook set
TELEGRAM_WEBHOOK_BASE_URL=
TELEGRAM_MINI_APP_URL=
TELEGRAM_DEFAULT_LANGUAGE=en
TELEGRAM_SUPPORTED_LANGUAGES=en,ro,ru,sr,hu,it,de
MINI_APP_API_BASE_URL=http://127.0.0.1:8000
# Mini App UI process only (Railway/Docker): bind address (default 0.0.0.0 when PORT is set in mini_app/main.py).
# FLET_HOST=0.0.0.0
MINI_APP_DEFAULT_LANGUAGE=en
# Dev-only Telegram user id for Mini App API calls until init-data auth exists.
MINI_APP_DEV_TELEGRAM_USER_ID=100001
